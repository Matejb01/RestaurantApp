@page
@model ErrorModel
@{
    ViewData["Title"] = "Greška";
}

<div class="container mt-5 text-center">
    <h1 class="display-1">⚠️</h1>
    <h2>Došlo je do greške</h2>
    <p class="text-muted">Nešto je pošlo po krivu. Molimo pokušajte ponovo.</p>
    @if (Model.RequestId != null)
    {
        <p class="text-muted small">Request ID: @Model.RequestId</p>
    }
    <a asp-page="/Index" class="btn btn-primary mt-3">← Povratak na početnu</a>
</div>