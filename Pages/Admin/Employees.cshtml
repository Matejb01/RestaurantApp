@page
@model RestaurantApp.Pages.Admin.EmployeesModel
@{
    ViewData["Title"] = "Upravljanje zaposlenicima";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>👥 Upravljanje zaposlenicima</h1>
        <div class="d-flex align-items-center gap-3">
            <span class="text-muted">Admin: <strong>@Model.AdminIme</strong></span>
            <a asp-page="/Admin/MenuManagement" class="btn btn-outline-primary btn-sm">
                🍽️ Meni
            </a>
            <form method="post" asp-page-handler="Logout">
                <button type="submit" class="btn btn-outline-secondary btn-sm">Odjava</button>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show">
            @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <div class="row">
        <!-- Add/Edit form -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0">
                        @(Model.FormZaposlenik.Id == 0 ? "➕ Dodaj zaposlenika" : "✏️ Uredi zaposlenika")
                    </h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="Save">
                        <input type="hidden" asp-for="FormZaposlenik.Id" />
                        <div class="mb-3">
                            <label class="form-label">Ime *</label>
                            <input asp-for="FormZaposlenik.Ime" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Prezime *</label>
                            <input asp-for="FormZaposlenik.Prezime" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Korisničko ime *</label>
                            <input asp-for="FormZaposlenik.KorisnickoIme" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">
                                Lozinka @(Model.FormZaposlenik.Id != 0 ? "(ostavite prazno za zadržavanje)" : "*")
                            </label>
                            @if (Model.FormZaposlenik.Id == 0)
                            {
                                <input asp-for="FormZaposlenik.Lozinka" type="password" class="form-control" required />
                            }
                            else
                            {
                                <input asp-for="FormZaposlenik.Lozinka" type="password" class="form-control" />
                            }
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Uloga *</label>
                            <select asp-for="FormZaposlenik.Uloga" class="form-select" required>
                                <option value="Zaposlenik">Zaposlenik</option>
                                <option value="Administrator">Administrator</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            @(Model.FormZaposlenik.Id == 0 ? "Dodaj" : "Spremi izmjene")
                        </button>
                        @if (Model.FormZaposlenik.Id != 0)
                        {
                            <a asp-page="/Admin/Employees" class="btn btn-outline-secondary w-100 mt-2">
                                Odustani
                            </a>
                        }
                    </form>
                </div>
            </div>
        </div>

        <!-- Employees list -->
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0">Zaposlenici (@Model.Zaposlenici.Count)</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Ime i prezime</th>
                                <th>Korisničko ime</th>
                                <th>Uloga</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var z in Model.Zaposlenici)
                            {
                                <tr>
                                    <td>@z.Ime @z.Prezime</td>
                                    <td><code>@z.KorisnickoIme</code></td>
                                    <td>
                                        <span class="badge @(z.Uloga == "Administrator" ? "bg-danger" : "bg-primary")">
                                            @z.Uloga
                                        </span>
                                    </td>
                                    <td>
                                        <a asp-page="/Admin/Employees" asp-route-editId="@z.Id"
                                           class="btn btn-outline-warning btn-sm">✏️</a>
                                        @if (z.Id != Model.CurrentAdminId)
                                        {
                                            <form method="post" asp-page-handler="Delete"
                                                  style="display:inline"
                                                  onsubmit="return confirm('Obrisati @z.Ime @z.Prezime?')">
                                                <input type="hidden" name="zaposlenikId" value="@z.Id" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm">🗑</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Vi</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>