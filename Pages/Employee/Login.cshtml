@page
@model RestaurantApp.Pages.Employee.LoginModel
@{
    ViewData["Title"] = "Prijava zaposlenika";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-header text-center">
                    <h4>🔐 Prijava zaposlenika</h4>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger">@Model.ErrorMessage</div>
                    }
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label">Korisničko ime</label>
                            <input asp-for="KorisnickoIme" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Lozinka</label>
                            <input asp-for="Lozinka" type="password" class="form-control" />
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Prijava</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>